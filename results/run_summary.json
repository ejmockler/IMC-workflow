        "membership_axes": {
          "_comment": "Three-axis decomposition for continuous multi-label annotation. Each superpixel gets independent scores on each axis. Lineage memberships are non-exclusive (interfaces score on multiple). Subtypes use within-family negatives only. Activation is an independent overlay.",
          "normalization": "sigmoid_threshold",
          "sigmoid_steepness": 10.0,
          "lineages": {
            "_comment": "Positive-only markers. No cross-lineage negatives \u2014 a superpixel can be immune AND endothelial (tissue interface). Scores are continuous [0,1] normalized expression.",
            "immune": {
              "markers": [
                "CD45"
              ],
              "aggregation": "max"
            },
            "endothelial": {
              "markers": [
                "CD31",
                "CD34"
              ],
              "aggregation": "mean"
            },
            "stromal": {
              "markers": [
                "CD140a"
              ],
              "aggregation": "max"
            }
          },
          "subtypes": {
            "_comment": "Within-lineage refinement. Negatives are only within the same lineage branch (e.g., CD206 separates M2 from non-M2 myeloid). Evaluated only when parent lineage score exceeds subtype_threshold.",
            "subtype_threshold": 0.3,
