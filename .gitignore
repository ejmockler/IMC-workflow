# Generated artifacts
.hypothesis/
htmlcov/
.coverage
*.pyc
__pycache__/
.pytest_cache/
*.egg-info/
dist/
build/
.env
.venv/
venv/
*.log
*.backup

# Data files - should not be in version control
data/
*.txt
*.csv
*.mcd
*.jpg
*.png
*.pdf
*.json.gz

# Track results directory (negations override glob patterns above)
!results/
!results/**

# IDE and OS files
.DS_Store
.vscode/
.claude/
*.swp
*.swo

# Local archive directory: rollover backups produced by --archive-prior flags;
# not under version control (each archive snapshot is megabytes of pre-refactor
# state that's already represented by the corresponding commit)
results/archive/

# Project-specific generated files
quality_history.json
project_registry.json
analysis_log.txt
relative_path.pdf
test_figure*.png
test_heterogeneity.png
